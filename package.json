{
  "name": "dashboard",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": ["server", "web"],
  "scripts": {
    "dev": "npm run dev -w web",
    "build": "npm run build -w web",
    "backend:start": "cd server && npm start",
    "backend:dev": "cd server && npm run dev",
    "dev:all": "concurrently -n api,web -c blue,green \"npm run backend:dev\" \"npm run dev\"",
    "start": "NODE_ENV=production node server/index.js",
    "seed:admin": "node scripts/seed-admin.js",
    "test": "npm run test -w server && npm run test -w web"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
